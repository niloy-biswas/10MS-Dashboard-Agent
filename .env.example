# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Set MODEL_PROVIDER to "anthropic" or "openai" — this is the only switch needed
# to change the active provider. The matching API key and default model will be used.

MODEL_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o

# ─── BigQuery ─────────────────────────────────────────────────────────────────
BIGQUERY_PROJECT=your-gcp-project-id
BIGQUERY_LOCATION=US

# Service account key JSON — minified to a single line (no newlines)
# Generate from GCP Console > IAM & Admin > Service Accounts > Keys > Add Key > JSON
# Required roles: BigQuery Data Viewer + BigQuery Job User
# Locally you can omit this and use Application Default Credentials (gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ─── Opik Tracing (optional) ─────────────────────────────────────────────────
# Sign up at https://www.comet.com/opik to get an API key
OPIK_API_KEY=your_opik_api_key
OPIK_PROJECT_NAME=10ms-analytics
OPIK_WORKSPACE=your-workspace-name
OPIK_URL_OVERRIDE=https://www.comet.com/opik/api